# ==============================================================================
# AI Proxy URLs Configuration
# ==============================================================================
#
# IMPORTANT: The AI dock icon will only appear when at least one proxy is configured.
# Without these URLs, the editor will work but AI features will be disabled.
#
# These proxies are required because AI provider API keys (Anthropic, OpenAI, Fal.ai)
# should NOT be exposed in client-side code. Your proxy servers should:
# 1. Hold API keys securely on the server side
# 2. Forward requests from the browser to the AI provider
# 3. Return responses to the browser
#
# For proxy server examples, see: https://img.ly/docs/cesdk/js/plugins/ai-generation/
#
# ==============================================================================

# Fal.ai proxy (for Recraft V3, Seedream V4, NanoBanana, Ideogram V3, Gemini Flash, Flux)
# This enables most image generation capabilities
VITE_FAL_AI_PROXY_URL=

# Anthropic proxy (for Claude Sonnet 4.5 - text generation)
VITE_ANTHROPIC_PROXY_URL=

# OpenAI proxy (for GPT-4.1 Nano text + GPT Image 1)
VITE_OPENAI_PROXY_URL=
